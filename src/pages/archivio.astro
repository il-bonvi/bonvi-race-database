---
import Base from '../layouts/Base.astro';
import GaraCard from '../components/GaraCard.astro';
import LangSwitcher from '../components/LangSwitcher.astro';
import { GENERI, CATEGORIE, DISCIPLINE } from '../lib/gare.js';

const garaFiles = import.meta.glob('../../gare-sorgenti/dettagli/*.json', { eager: true });
let gare = Object.values(garaFiles).map((m: any) => m.default ?? m);

// Nasconde le singole tappe (le corse a tappe si vedono tramite la card principale)
gare = gare.filter((g: any) => g.tipo !== 'tappa');

gare.sort((a: any, b: any) => new Date(b.data).getTime() - new Date(a.data).getTime());

const anni = [...new Set(gare.map(g => new Date(g.data).getFullYear()))].sort((a,b) => b-a);
const totKm = gare.reduce((s, g) => s + (Number(g.distanza_km) || 0), 0);

const MONTH_NAMES = ['Gennaio', 'Febbraio', 'Marzo', 'Aprile', 'Maggio', 'Giugno', 'Luglio', 'Agosto', 'Settembre', 'Ottobre', 'Novembre', 'Dicembre'];
const groupedByYear = new Map();
gare.forEach(g => {
  const d = new Date(g.data);
  const year = d.getFullYear();
  const month = d.getMonth();
  if (!groupedByYear.has(year)) groupedByYear.set(year, new Map());
  if (!groupedByYear.get(year).has(month)) groupedByYear.get(year).set(month, []);
  groupedByYear.get(year).get(month).push(g);
});

const yearMonthStructure = Array.from(groupedByYear.entries())
  .sort(([yearA]: [any, any], [yearB]: [any, any]) => yearB - yearA)
  .map(([year, monthsMap]: [any, any]) => ({
    year,
    months: Array.from(monthsMap.entries())
      .sort(([monthA]: [any, any], [monthB]: [any, any]) => monthB - monthA)
      .map(([month, races]: [any, any]) => ({
        month,
        races: races.slice().sort((a: any, b: any) => new Date(a.data).getTime() - new Date(b.data).getTime()),
        monthKey: `${year}-${String(month).padStart(2, '0')}`
      }))
  }));

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Archivio — Race Database">
<div class="layout">

  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-inner">

      <div class="brand">
        <div class="brand-mark">BRD</div>
        <div>
          <div class="brand-name">Race Database</div>
          <div class="brand-sub" data-i18n="page_archive_tag">Archivio</div>
        </div>
      </div>

      <div class="db-stats">
        <div class="db-stat">
          <span class="db-n" id="count-visible">{gare.length}</span>
          <span class="db-l" data-i18n="stat_routes">percorsi</span>
        </div>
        <div class="db-stat">
          <span class="db-n" id="km-visible">{totKm.toFixed(0)}</span>
          <span class="db-l" data-i18n="stat_km">km totali</span>
        </div>
        <div class="db-stat">
          <span class="db-n" id="dislivello-visible">{gare.reduce((s, g) => s + (Number(g.dislivello_m) || 0), 0).toFixed(0)}</span>
          <span class="db-l" data-i18n="stat_elev">m dislivello totali</span>
        </div>
      </div>

      <div class="filters">

        <div class="filter-group">
          <div class="filter-label" data-i18n="filter_year">Anno</div>
          <div class="filter-pills">
            <button class="pill active" data-group="anno" data-val="all" data-i18n="filter_all_y">Tutti</button>
            {anni.map(a => (
              <button class="pill" data-group="anno" data-val={String(a)}>{a}</button>
            ))}
          </div>
        </div>

        <div class="filter-group">
          <div class="filter-label" data-i18n="filter_gender">Genere</div>
          <div class="filter-pills">
            <button class="pill active" data-group="genere" data-val="all" data-i18n="filter_all_g">Tutti</button>
            {GENERI.map(g => (
              <button class="pill" data-group="genere" data-val={g} data-i18n-gen={g}>{g}</button>
            ))}
          </div>
        </div>

        <div class="filter-group">
          <div class="filter-label" data-i18n="filter_cat">Categoria</div>
          <div class="filter-pills">
            <button class="pill active" data-group="categoria" data-val="all" data-i18n="filter_all_c">Tutte</button>
            {CATEGORIE.map(c => (
              <button class="pill" data-group="categoria" data-val={c} data-i18n-cat={c}>{c}</button>
            ))}
          </div>
        </div>

        <div class="filter-group">
          <div class="filter-label" data-i18n="filter_disc">Disciplina</div>
          <div class="filter-pills">
            <button class="pill active" data-group="disciplina" data-val="all" data-i18n="filter_all_d">Tutte</button>
            {DISCIPLINE.map(d => (
              <button class="pill" data-group="disciplina" data-val={d} data-i18n-disc={d}>{d}</button>
            ))}
          </div>
        </div>

        <button class="reset-filters" id="reset-filters" data-i18n="filter_reset">Azzera filtri</button>
      </div>

      <div class="sidebar-footer">
        <a href={`${base}`} class="sidebar-page-btn" data-i18n="nav_upcoming">Prossime Gare</a>
        <a href={`${base}/bmap`} class="sidebar-page-btn" data-i18n="nav_bmap">BMAP</a>
        <a href={`${base}/progetto`} class="sidebar-page-btn" data-i18n="nav_project">Il Progetto</a>
        <a href={`${base}/faq`} class="sidebar-page-btn" data-i18n="nav_faq">FAQ</a>
        <a href={`${base}/contattami`} class="sidebar-page-btn" data-i18n="nav_contact">Contattami</a>
      </div>

    </div>
  </aside>

  <main class="main">

    <div class="topbar">
      <button class="mobile-menu-btn" id="menu-btn" aria-label="Apri menu">☰</button>
      <div class="search-wrap">
        <span class="search-icon">⌕</span>
        <input type="text" id="search-input" class="search-input" placeholder="Cerca per nome, luogo..." data-i18n-placeholder="search_placeholder" autocomplete="off" />
      </div>
      <div class="sort-wrap">
        <label class="sort-label" data-i18n="sort_label">Ordina</label>
        <select id="sort-select" class="sort-select">
          <option value="data-asc" selected data-i18n-option="sort_date_asc">Data ↑</option>
          <option value="data-desc" data-i18n-option="sort_date_desc">Data ↓</option>
          <option value="km-desc" data-i18n-option="sort_km_desc">Km ↓</option>
          <option value="km-asc" data-i18n-option="sort_km_asc">Km ↑</option>
          <option value="nome" data-i18n-option="sort_name">Nome A→Z</option>
        </select>
      </div>
      <LangSwitcher />
    </div>

    <div class="timeline" id="gare-timeline">
      {gare.length === 0 ? (
        <div class="empty">
          <div class="empty-icon">◎</div>
          <div class="empty-title" data-i18n="empty_title">Archivio vuoto</div>
          <div class="empty-sub">Non hai gare passate ancora</div>
        </div>
      ) : (
        yearMonthStructure.map(({ year, months }: any) => {
          const yearTotalRaces = months.reduce((sum, m) => sum + m.races.length, 0);
          return (
            <div class="year-group collapsed" data-year={year}>
              <button class="year-header" data-year-toggle={year}>
                <span class="year-chevron">▼</span>
                <span class="year-label"><strong>{year}</strong></span>
                <span class="year-count">({yearTotalRaces})</span>
              </button>
              <div class="year-races" style="display: none">
                {months.map(({ month, races, monthKey }: any) => (
                  <div class="month-group collapsed" data-month-key={monthKey}>
                    <button class="month-header" data-month-toggle={monthKey}>
                      <span class="month-chevron">▼</span>
                      <span class="month-label" data-i18n-month={month}>{MONTH_NAMES[month]}</span>
                      <span class="month-count">({races.length})</span>
                    </button>
                    <div class="month-races" style="display: none">
                      {races.map((g: any) => (
                        <div class="card-wrap"
                          data-anno={year}
                          data-genere={g.genere ?? ''}
                          data-categoria={g.categoria ?? ''}
                          data-categorie-json={JSON.stringify(Array.isArray(g.categoria) ? g.categoria : (g.categoria ? [g.categoria] : []))}
                          data-disciplina={g.disciplina ?? ''}
                          data-titolo={(g.titolo ?? '').toLowerCase()}
                          data-luogo={(g.luogo ?? '').toLowerCase()}
                          data-km={g.distanza_km ?? 0}
                          data-dislivello={g.dislivello_m ?? 0}
                          data-month={monthKey}
                          data-date={new Date(g.data).getTime()}
                        >
                          <GaraCard gara={g} />
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          );
        })
      )}
    </div>

    <div class="no-results" id="no-results" style="display:none">
      <div class="empty-icon">◎</div>
      <div class="empty-title" data-i18n="no_results">Nessun risultato</div>
      <div class="empty-sub" data-i18n="no_results_sub">Prova a modificare i filtri</div>
    </div>

  </main>

  <footer>
    <a href="https://linktr.ee/bonvicin.coaching" target="_blank" data-i18n="footer_copy">
      &copy; 2026 Andrea Bonvicin — BRD Race Database — Licenza AGPL v3
    </a>
  </footer>

</div>
</Base>

<script>
  const state = { anno: 'all', genere: 'all', categoria: 'all', disciplina: 'all', q: '', sort: 'data-asc' };
  const cards = Array.from(document.querySelectorAll('.card-wrap')) as HTMLElement[];
  const counter = document.getElementById('count-visible') as HTMLElement;
  const kmCounter = document.getElementById('km-visible') as HTMLElement;
  const dislivelloCounter = document.getElementById('dislivello-visible') as HTMLElement;
  const noRes = document.getElementById('no-results') as HTMLElement;
  const timeline = document.getElementById('gare-timeline') as HTMLElement;

  function applyAll() {
    let visible = 0;
    let totalKm = 0;
    let totalDislivello = 0;

    cards.forEach((card: HTMLElement) => {
      const anno = card.dataset.anno ?? '';
      const genere = card.dataset.genere ?? '';
      const categorieJson = card.dataset.categorieJson ?? '[]';
      const categorie: string[] = JSON.parse(categorieJson);
      const disciplina = card.dataset.disciplina ?? '';
      const titolo = card.dataset.titolo ?? '';
      const luogo = card.dataset.luogo ?? '';

      const matchAnno = state.anno === 'all' || anno === state.anno;
      const matchGenere = state.genere === 'all' || genere === state.genere;
      const matchCategoria = state.categoria === 'all' || categorie.includes(state.categoria);
      const matchDisciplina = state.disciplina === 'all' || disciplina === state.disciplina;
      const q = state.q.toLowerCase();
      const matchQ = !q || titolo.includes(q) || luogo.includes(q);

      const show = matchAnno && matchGenere && matchCategoria && matchDisciplina && matchQ;
      card.style.display = show ? '' : 'none';
      if (show) {
        visible++;
        totalKm += parseFloat(card.dataset.km ?? '0') || 0;
        totalDislivello += parseFloat(card.dataset.dislivello ?? '0') || 0;
      }
    });

    if (counter) counter.textContent = String(visible);
    if (kmCounter) kmCounter.textContent = totalKm.toFixed(0);
    if (dislivelloCounter) dislivelloCounter.textContent = totalDislivello.toFixed(0);

    document.querySelectorAll('.month-group').forEach((mg: Element) => {
      const mgEl = mg as HTMLElement;
      const vis = Array.from(mgEl.querySelectorAll('.card-wrap')).some(c => (c as HTMLElement).style.display !== 'none');
      mgEl.style.display = vis ? '' : 'none';
    });

    document.querySelectorAll('.year-group').forEach((yg: Element) => {
      const ygEl = yg as HTMLElement;
      const vis = Array.from(ygEl.querySelectorAll('.card-wrap')).some(c => (c as HTMLElement).style.display !== 'none');
      ygEl.style.display = vis ? '' : 'none';
    });

    noRes.style.display = visible === 0 && cards.length > 0 ? '' : 'none';

    sortCards();
  }

  function sortCards() {
    const sorted = [...cards].filter(c => c.style.display !== 'none').sort((a, b) => {
      if (state.sort === 'data-asc') return Number(a.dataset.date ?? 0) - Number(b.dataset.date ?? 0);
      if (state.sort === 'data-desc') return Number(b.dataset.date ?? 0) - Number(a.dataset.date ?? 0);
      if (state.sort === 'km-desc') return Number(b.dataset.km ?? 0) - Number(a.dataset.km ?? 0);
      if (state.sort === 'km-asc') return Number(a.dataset.km ?? 0) - Number(b.dataset.km ?? 0);
      if (state.sort === 'nome') return (a.dataset.titolo ?? '').localeCompare(b.dataset.titolo ?? '');
      return 0;
    });
    const rankMap = new Map(sorted.map((c, i) => [c, i]));
    document.querySelectorAll('.month-races').forEach((racesContainer: Element) => {
      const visible = Array.from(racesContainer.querySelectorAll('.card-wrap')).filter(c => (c as HTMLElement).style.display !== 'none') as HTMLElement[];
      visible.sort((a, b) => (rankMap.get(a) ?? 0) - (rankMap.get(b) ?? 0));
      visible.forEach(c => racesContainer.appendChild(c));
    });
  }

  // ── Salva/ripristina stato collapsed su sessionStorage ──
  const STORAGE_KEY = 'brd-archivio-open';

  function saveOpenState() {
    const openYears = Array.from(document.querySelectorAll('.year-group.expanded'))
      .map(el => (el as HTMLElement).dataset.year ?? '');
    const openMonths = Array.from(document.querySelectorAll('.month-group.expanded'))
      .map(el => (el as HTMLElement).dataset.monthKey ?? '');
    sessionStorage.setItem(STORAGE_KEY, JSON.stringify({ years: openYears, months: openMonths }));
  }

    function restoreOpenState() {
    const raw = sessionStorage.getItem(STORAGE_KEY);
    if (!raw) return;
    try {
      const { years, months } = JSON.parse(raw);
      document.querySelectorAll('.year-group').forEach((el: Element) => {
        const group = el as HTMLElement;
        const year = group.dataset.year ?? '';
        const races = group.querySelector('.year-races') as HTMLElement;
        if (years.includes(year)) {
          group.classList.add('expanded'); group.classList.remove('collapsed');
          races.style.display = 'flex';
        }
      });
      document.querySelectorAll('.month-group').forEach((el: Element) => {
        const group = el as HTMLElement;
        const key = group.dataset.monthKey ?? '';
        const races = group.querySelector('.month-races') as HTMLElement;
        if (months.includes(key)) {
          group.classList.add('expanded'); group.classList.remove('collapsed');
          races.style.display = 'grid';
        }
      });
    } catch(e) {}
  }

    restoreOpenState();

  document.querySelectorAll('.year-header').forEach((btn: Element) => {
    btn.addEventListener('click', () => {
      const group = (btn as HTMLElement).closest('.year-group') as HTMLElement;
      const races = group.querySelector('.year-races') as HTMLElement;
      const isExpanded = group.classList.toggle('expanded');
      group.classList.toggle('collapsed', !isExpanded);
      races.style.display = isExpanded ? 'flex' : 'none';
      saveOpenState();
    });
  });

  document.querySelectorAll('.month-header').forEach((btn: Element) => {
    btn.addEventListener('click', () => {
      const group = (btn as HTMLElement).closest('.month-group') as HTMLElement;
      const races = group.querySelector('.month-races') as HTMLElement;
      const isExpanded = group.classList.toggle('expanded');
      group.classList.toggle('collapsed', !isExpanded);
      races.style.display = isExpanded ? 'grid' : 'none';
      saveOpenState();
    });
  });

  document.querySelectorAll('.pill').forEach((btn: Element) => {
    btn.addEventListener('click', () => {
      (btn as HTMLElement).closest('.filter-pills')!.querySelectorAll('.pill').forEach(b => b.classList.remove('active'));
      (btn as HTMLElement).classList.add('active');
      state[(btn as HTMLElement).dataset.group as keyof typeof state] = (btn as HTMLElement).dataset.val as string;
      applyAll();
    });
  });

  (document.getElementById('search-input') as HTMLInputElement).addEventListener('input', (e: Event) => {
    state.q = (e.target as HTMLInputElement).value;
    applyAll();
  });

  (document.getElementById('sort-select') as HTMLSelectElement).addEventListener('change', (e: Event) => {
    state.sort = (e.target as HTMLSelectElement).value;
    applyAll();
  });

  (document.getElementById('reset-filters') as HTMLElement).addEventListener('click', () => {
    state.anno = state.genere = state.categoria = state.disciplina = 'all';
    state.q = ''; state.sort = 'data-asc';
    (document.getElementById('search-input') as HTMLInputElement).value = '';
    (document.getElementById('sort-select') as HTMLSelectElement).value = 'data-asc';
    document.querySelectorAll('.pill').forEach((b: Element) => {
      b.classList.toggle('active', (b as HTMLElement).dataset.val === 'all');
    });
    applyAll();
  });

  // ── Mobile drawer ──────────────────────────────
  const menuBtn = document.getElementById('menu-btn') as HTMLElement;
  const overlay = document.getElementById('sidebar-overlay') as HTMLElement;
  const sidebar = document.getElementById('sidebar') as HTMLElement;

  function openDrawer() { sidebar.classList.add('open'); overlay.classList.add('open'); document.body.style.overflow = 'hidden'; }
  function closeDrawer() { sidebar.classList.remove('open'); overlay.classList.remove('open'); document.body.style.overflow = ''; }

  menuBtn?.addEventListener('click', openDrawer);
  overlay?.addEventListener('click', closeDrawer);
  document.querySelectorAll('.sidebar-page-btn').forEach(btn => btn.addEventListener('click', closeDrawer));

  // ── i18n runtime ──────────────────────────────
  (function() {
    const lang = localStorage.getItem('brd-lang') || 'it';
    if (lang === 'it') return;
    const T = (window as any).__brdTranslations?.[lang];
    if (!T) return;
    document.querySelectorAll('[data-i18n]').forEach((el: Element) => {
      const key = (el as HTMLElement).getAttribute('data-i18n')!;
      if (T[key] !== undefined) el.textContent = T[key];
    });
    document.querySelectorAll('[data-i18n-placeholder]').forEach((el: Element) => {
      const key = (el as HTMLElement).getAttribute('data-i18n-placeholder')!;
      if (T[key] !== undefined) (el as HTMLInputElement).placeholder = T[key];
    });
    document.querySelectorAll('[data-i18n-month]').forEach((el: Element) => {
      const idx = parseInt((el as HTMLElement).getAttribute('data-i18n-month')!, 10);
      if (!isNaN(idx) && T.months?.[idx]) el.textContent = T.months[idx];
    });
    document.querySelectorAll('[data-i18n-cat]').forEach((el: Element) => {
      const val = (el as HTMLElement).getAttribute('data-i18n-cat')!;
      if (T['cat_' + val] !== undefined) el.textContent = T['cat_' + val];
    });
    document.querySelectorAll('[data-i18n-gen]').forEach((el: Element) => {
      const val = (el as HTMLElement).getAttribute('data-i18n-gen')!;
      if (T['gen_' + val] !== undefined) el.textContent = T['gen_' + val];
    });
    document.querySelectorAll('[data-i18n-disc]').forEach((el: Element) => {
      const val = (el as HTMLElement).getAttribute('data-i18n-disc')!;
      if (T['disc_' + val] !== undefined) el.textContent = T['disc_' + val];
    });
    document.querySelectorAll('[data-i18n-option]').forEach((el: Element) => {
      const key = (el as HTMLElement).getAttribute('data-i18n-option')!;
      if (T[key] !== undefined) el.textContent = T[key];
    });
    document.querySelectorAll('.cat-badge[data-cat]').forEach((el: Element) => {
      const val = (el as HTMLElement).getAttribute('data-cat')!;
      if (T['cat_' + val] !== undefined) el.textContent = T['cat_' + val];
    });
    document.querySelectorAll('.stat-l[data-i18n-stat]').forEach((el: Element) => {
      const key = (el as HTMLElement).getAttribute('data-i18n-stat')!;
      if (T[key] !== undefined) el.textContent = T[key];
    });
  })();
</script>

<script>
  (window as any).__brdTranslations = {
    en: {
      nav_upcoming: 'Upcoming Races', nav_archive: 'Archive', nav_bmap: 'BMAP', nav_project: 'The Project',
      nav_faq: 'FAQ', nav_contact: 'Contact',
      stat_routes: 'routes', stat_km: 'total km', stat_elev: 'total elevation',
      filter_year: 'Year', filter_gender: 'Gender', filter_cat: 'Category',
      filter_disc: 'Discipline', filter_reset: 'Reset filters',
      filter_all_y: 'All', filter_all_g: 'All', filter_all_c: 'All', filter_all_d: 'All',
      search_placeholder: 'Search by name, location...',
      sort_label: 'Sort', sort_date_asc: 'Date ↑', sort_date_desc: 'Date ↓',
      sort_km_desc: 'Km ↓', sort_km_asc: 'Km ↑', sort_name: 'Name A→Z',
      card_cta: 'View route →',
      empty_title: 'Empty archive', empty_sub: 'No past races yet',
      no_results: 'No races found', no_results_sub: 'Try changing the filters or search query',
      page_archive_tag: 'Archive',
      footer_copy: '© 2026 Andrea Bonvicin — BRD Race Database — AGPL v3 License',
      cat_Allievi: 'U16', cat_Allieve: 'U16', cat_Junior: 'Junior', cat_U23: 'U23', cat_Elite: 'Elite',
      gen_Maschile: 'Men', gen_Femminile: 'Women',
      disc_Strada: 'Road Race', disc_Criterium: 'Criterium', disc_Cronometro: 'Time Trial',
      stat_dist: 'Distance', stat_elev_c: 'Elevation', stat_date: 'Date', stat_speed: 'Est. avg speed',
      months: ['January','February','March','April','May','June','July','August','September','October','November','December'],
    }
  };
</script>

<style>
  .layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    grid-template-rows: 1fr auto;
    min-height: 100vh;
  }

  .sidebar-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 99;
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }
  .sidebar-overlay.open { display: block; }

  .sidebar {
    background: var(--bg2);
    border-right: 1px solid var(--border);
    position: sticky; top: 0;
    height: 100vh; overflow-y: auto;
    grid-column: 1;
    grid-row: 1 / -1;
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }

  .sidebar-inner {
    display: flex; flex-direction: column;
    padding: 1.6rem 1.1rem;
    height: 100%; gap: 1.35rem;
  }

  .brand { display: flex; align-items: center; gap: 0.75rem; padding-bottom: 1.1rem; border-bottom: 1px solid var(--border); }
  .brand-mark { font-family: var(--font-display); font-size: 0.82rem; font-weight: 800; letter-spacing: 0.08em; background: var(--text); color: var(--bg); padding: 0.27rem 0.43rem; border-radius: 2px; flex-shrink: 0; }
  .brand-name { font-family: var(--font-display); font-size: 0.88rem; font-weight: 700; letter-spacing: 0.02em; color: var(--text); }
