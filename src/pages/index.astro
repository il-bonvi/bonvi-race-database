---
import Base from '../layouts/Base.astro';
import GaraCard from '../components/GaraCard.astro';
import { GENERI, CATEGORIE, DISCIPLINE } from '../lib/gare.js';

const garaFiles = import.meta.glob('../../gare-sorgenti/dettagli/*.json', { eager: true });
let gare = Object.values(garaFiles).map((m: any) => m.default ?? m);

// Filtra solo gare future (da oggi in poi)
const today = new Date();
today.setHours(0, 0, 0, 0);
gare = gare.filter((g: any) => new Date(g.data) >= today);

gare.sort((a: any, b: any) => new Date(b.data).getTime() - new Date(a.data).getTime());

const anni = [...new Set(gare.map(g => new Date(g.data).getFullYear()))].sort((a,b) => b-a);
const totKm = gare.reduce((s, g) => s + (Number(g.distanza_km) || 0), 0);

const MONTH_NAMES = ['Gennaio', 'Febbraio', 'Marzo', 'Aprile', 'Maggio', 'Giugno', 'Luglio', 'Agosto', 'Settembre', 'Ottobre', 'Novembre', 'Dicembre'];
const groupedByYear = new Map();
gare.forEach(g => {
  const d = new Date(g.data);
  const year = d.getFullYear();
  const month = d.getMonth();
  if (!groupedByYear.has(year)) groupedByYear.set(year, new Map());
  if (!groupedByYear.get(year).has(month)) groupedByYear.get(year).set(month, []);
  groupedByYear.get(year).get(month).push(g);
});

const yearMonthStructure = Array.from(groupedByYear.entries())
  .sort(([yearA]: [any, any], [yearB]: [any, any]) => yearB - yearA)
  .map(([year, monthsMap]: [any, any]) => ({
    year,
    months: Array.from(monthsMap.entries())
      .sort(([monthA]: [any, any], [monthB]: [any, any]) => monthB - monthA)
      .map(([month, races]: [any, any]) => ({
        month,
        races: races.slice().sort((a: any, b: any) => new Date(a.data).getTime() - new Date(b.data).getTime()),
        monthKey: `${year}-${String(month).padStart(2, '0')}`
      }))
  }));

const currentYear = today.getFullYear();
const currentMonth = today.getMonth();

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Race Database — by Bonvi">
<div class="layout">

  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-inner">

      <div class="brand">
        <div class="brand-mark">BRD</div>
        <div>
          <div class="brand-name">Race Database</div>
          <div class="brand-sub">by Bonvi</div>
        </div>
      </div>

      <div class="db-stats">
        <div class="db-stat">
          <span class="db-n" id="count-visible">{gare.length}</span>
          <span class="db-l">percorsi</span>
        </div>
        <div class="db-stat">
          <span class="db-n" id="km-visible">{totKm.toFixed(0)}</span>
          <span class="db-l">km totali</span>
        </div>
        <div class="db-stat">
          <span class="db-n" id="dislivello-visible">{gare.reduce((s, g) => s + (Number(g.dislivello_m) || 0), 0).toFixed(0)}</span>
          <span class="db-l">m dislivello totali</span>
        </div>
      </div>

      <div class="filters">

        <div class="filter-group">
          <div class="filter-label">Anno</div>
          <div class="filter-pills">
            <button class="pill active" data-group="anno" data-val="all">Tutti</button>
            {anni.map(a => (
              <button class="pill" data-group="anno" data-val={String(a)}>{a}</button>
            ))}
          </div>
        </div>

        <div class="filter-group">
          <div class="filter-label">Genere</div>
          <div class="filter-pills">
            <button class="pill active" data-group="genere" data-val="all">Tutti</button>
            {GENERI.map(g => (
              <button class="pill" data-group="genere" data-val={g}>{g}</button>
            ))}
          </div>
        </div>

        <div class="filter-group">
          <div class="filter-label">Categoria</div>
          <div class="filter-pills">
            <button class="pill active" data-group="categoria" data-val="all">Tutte</button>
            {CATEGORIE.map(c => (
              <button class="pill" data-group="categoria" data-val={c}>{c}</button>
            ))}
          </div>
        </div>

        <div class="filter-group">
          <div class="filter-label">Disciplina</div>
          <div class="filter-pills">
            <button class="pill active" data-group="disciplina" data-val="all">Tutte</button>
            {DISCIPLINE.map(d => (
              <button class="pill" data-group="disciplina" data-val={d}>{d}</button>
            ))}
          </div>
        </div>

        <button class="reset-filters" id="reset-filters">Azzera filtri</button>
      </div>

      <div class="sidebar-footer">
        <a href={`${base}/archivio`} class="sidebar-page-btn">Archivio</a>
        <a href={`${base}/progetto`} class="sidebar-page-btn">Il Progetto</a>
        <a href={`${base}/faq`} class="sidebar-page-btn">FAQ</a>
        <a href={`${base}/contattami`} class="sidebar-page-btn">Contattami</a>
      </div>

    </div>
  </aside>

  <main class="main">

    <div class="topbar">
      <button class="mobile-menu-btn" id="menu-btn" aria-label="Apri menu">☰</button>
      <div class="search-wrap">
        <span class="search-icon">⌕</span>
        <input type="text" id="search-input" class="search-input" placeholder="Cerca per nome, luogo..." autocomplete="off" />
      </div>
      <div class="sort-wrap">
        <label class="sort-label">Ordina</label>
        <select id="sort-select" class="sort-select">
          <option value="data-asc" selected>Data ↑</option>
          <option value="data-desc">Data ↓</option>
          <option value="km-desc">Km ↓</option>
          <option value="km-asc">Km ↑</option>
          <option value="nome">Nome A→Z</option>
        </select>
      </div>
    </div>

    <div class="timeline" id="gare-timeline">
      {gare.length === 0 ? (
        <div class="empty">
          <div class="empty-icon">◎</div>
          <div class="empty-title">Database vuoto</div>
          <div class="empty-sub">Aggiungi il primo percorso seguendo le istruzioni nel README</div>
        </div>
      ) : (
        yearMonthStructure.map(({ year, months }: any) => {
          const yearTotalRaces = months.reduce((sum, m) => sum + m.races.length, 0);
          const isCurrentYear = year === currentYear;
          return (
            <div class={`year-group ${isCurrentYear ? 'expanded' : 'collapsed'}`} data-year={year}>
              <button class="year-header" data-year-toggle={year}>
                <span class="year-chevron">▼</span>
                <span class="year-label"><strong>{year}</strong></span>
                <span class="year-count">({yearTotalRaces})</span>
              </button>
              <div class="year-races" style={`display: ${isCurrentYear ? 'flex' : 'none'}`}>
                {months.map(({ month, races, monthKey }: any) => {
                  const isCurrentMonth = isCurrentYear && month === currentMonth;
                  return (
                    <div class={`month-group ${isCurrentMonth ? 'expanded' : 'collapsed'}`} data-month={monthKey}>
                      <button class="month-header" data-month-toggle={monthKey}>
                        <span class="month-chevron">▼</span>
                        <span class="month-label">{MONTH_NAMES[month]}</span>
                        <span class="month-count">({races.length})</span>
                      </button>
                      <div class="month-races" style={`display: ${isCurrentMonth ? 'grid' : 'none'}`}>
                        {races.map((g: any) => (
                          <div class="card-wrap"
                            data-anno={new Date(g.data).getFullYear()}
                            data-genere={g.genere ?? ''}
                            data-categoria={g.categoria ?? ''}
                            data-disciplina={g.disciplina ?? ''}
                            data-titolo={(g.titolo ?? '').toLowerCase()}
                            data-luogo={(g.luogo ?? '').toLowerCase()}
                            data-km={g.distanza_km ?? 0}
                            data-dislivello={g.dislivello_m ?? 0}
                            data-month={monthKey}
                            data-date={new Date(g.data).getTime()}
                          >
                            <GaraCard gara={g} />
                          </div>
                        ))}
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })
      )}
    </div>

    <div class="no-results" id="no-results" style="display:none">
      <div class="empty-icon">◎</div>
      <div class="empty-title">Nessun risultato</div>
      <div class="empty-sub">Prova a modificare i filtri</div>
    </div>

  </main>

  <footer>
    <a href="https://linktr.ee/bonvicin.coaching" target="_blank">
      &copy; 2026 Andrea Bonvicin — RaceArchive — Licenza AGPL v3
    </a>
  </footer>

</div>
</Base>

<script>
  const state = { anno: 'all', genere: 'all', categoria: 'all', disciplina: 'all', q: '', sort: 'data-asc' };
  const cards = Array.from(document.querySelectorAll('.card-wrap')) as HTMLElement[];
  const counter = document.getElementById('count-visible') as HTMLElement;
  const kmCounter = document.getElementById('km-visible') as HTMLElement;
  const dislivelloCounter = document.getElementById('dislivello-visible') as HTMLElement;
  const noRes = document.getElementById('no-results') as HTMLElement;
  const timeline = document.getElementById('gare-timeline') as HTMLElement;

  document.querySelectorAll('.year-header').forEach((btn: Element) => {
    btn.addEventListener('click', () => {
      const group = (btn as HTMLElement).closest('.year-group') as HTMLElement;
      const races = group.querySelector('.year-races') as HTMLElement;
      const isExpanded = group.classList.toggle('expanded');
      group.classList.toggle('collapsed', !isExpanded);
      races.style.display = isExpanded ? 'flex' : 'none';
    });
  });

  document.querySelectorAll('.month-header').forEach((btn: Element) => {
    btn.addEventListener('click', () => {
      const group = (btn as HTMLElement).closest('.month-group') as HTMLElement;
      const races = group.querySelector('.month-races') as HTMLElement;
      const isExpanded = group.classList.toggle('expanded');
      group.classList.toggle('collapsed', !isExpanded);
      races.style.display = isExpanded ? 'grid' : 'none';
    });
  });

  function applyAll() {
    let visibleCount = 0;
    let visibleKm = 0;
    let visibleDislivello = 0;
    cards.forEach((c: HTMLElement) => {
      const match =
        (state.anno === 'all' || c.dataset.anno === state.anno) &&
        (state.genere === 'all' || c.dataset.genere === state.genere) &&
        (state.categoria === 'all' || c.dataset.categoria === state.categoria) &&
        (state.disciplina === 'all' || c.dataset.disciplina === state.disciplina) &&
        (!state.q || (c.dataset.titolo ?? '').includes(state.q.toLowerCase()) || (c.dataset.luogo ?? '').includes(state.q.toLowerCase()));
      c.style.display = match ? '' : 'none';
      if (match) {
        visibleCount++;
        visibleKm += parseFloat(c.dataset.km ?? '0') || 0;
        visibleDislivello += parseFloat(c.dataset.dislivello ?? '0') || 0;
      }
    });
    counter.textContent = String(visibleCount);
    kmCounter.textContent = visibleKm.toFixed(0);
    dislivelloCounter.textContent = visibleDislivello.toFixed(0);

    document.querySelectorAll('.month-group').forEach((group: Element) => {
      const monthRaces = group.querySelector('.month-races') as HTMLElement;
      if (!monthRaces) return;
      const hasVisible = Array.from(monthRaces.querySelectorAll('.card-wrap')).some(
        (c: Element) => (c as HTMLElement).style.display !== 'none'
      );
      (group as HTMLElement).style.display = hasVisible ? '' : 'none';
    });

    document.querySelectorAll('.year-group').forEach((group: Element) => {
      const hasVisible = Array.from(group.querySelectorAll('.month-group')).some(
        (g: Element) => (g as HTMLElement).style.display !== 'none'
      );
      (group as HTMLElement).style.display = hasVisible ? '' : 'none';
    });

    noRes.style.display = visibleCount === 0 ? '' : 'none';

    applySorting();
  }

  function applySorting() {
    const sorted = [...cards].filter((c: HTMLElement) => c.style.display !== 'none').sort((a: HTMLElement, b: HTMLElement) => {
      if (state.sort === 'data-asc') return Number(a.dataset.date ?? 0) - Number(b.dataset.date ?? 0);
      if (state.sort === 'data-desc') return Number(b.dataset.date ?? 0) - Number(a.dataset.date ?? 0);
      if (state.sort === 'km-desc') return Number(b.dataset.km ?? 0) - Number(a.dataset.km ?? 0);
      if (state.sort === 'km-asc') return Number(a.dataset.km ?? 0) - Number(b.dataset.km ?? 0);
      if (state.sort === 'nome') return (a.dataset.titolo ?? '').localeCompare(b.dataset.titolo ?? '');
      return 0;
    });

    const rankMap = new Map(sorted.map((c, i) => [c, i]));
    document.querySelectorAll('.month-races').forEach((racesContainer: Element) => {
      const cardsInContainer = Array.from(racesContainer.querySelectorAll('.card-wrap')) as HTMLElement[];
      const visibleCards = cardsInContainer.filter((c: HTMLElement) => c.style.display !== 'none');
      visibleCards.sort((a: HTMLElement, b: HTMLElement) => (rankMap.get(a) ?? 0) - (rankMap.get(b) ?? 0));
      visibleCards.forEach((c: HTMLElement) => racesContainer.appendChild(c));
    });
  }

  document.querySelectorAll('.pill').forEach((btn: Element) => {
    btn.addEventListener('click', () => {
      const filterPills = (btn as HTMLElement).closest('.filter-pills') as HTMLElement;
      filterPills.querySelectorAll('.pill').forEach((b: Element) => b.classList.remove('active'));
      (btn as HTMLElement).classList.add('active');
      const group = (btn as HTMLElement).dataset.group as string;
      const val = (btn as HTMLElement).dataset.val as string;
      state[group as keyof typeof state] = val;
      applyAll();
    });
  });

  (document.getElementById('search-input') as HTMLInputElement).addEventListener('input', (e: Event) => {
    state.q = (e.target as HTMLInputElement).value;
    applyAll();
  });

  (document.getElementById('sort-select') as HTMLSelectElement).addEventListener('change', (e: Event) => {
    state.sort = (e.target as HTMLSelectElement).value;
    applyAll();
  });

  (document.getElementById('reset-filters') as HTMLElement).addEventListener('click', () => {
    state.anno = state.genere = state.categoria = state.disciplina = 'all';
    state.q = ''; state.sort = 'data-asc';
    (document.getElementById('search-input') as HTMLInputElement).value = '';
    (document.getElementById('sort-select') as HTMLSelectElement).value = 'data-asc';
    document.querySelectorAll('.pill').forEach((b: Element) => {
      const val = (b as HTMLElement).dataset.val;
      b.classList.toggle('active', val === 'all');
    });
    applyAll();
  });

  // ── Mobile drawer ──────────────────────────────
  const menuBtn = document.getElementById('menu-btn') as HTMLElement;
  const overlay = document.getElementById('sidebar-overlay') as HTMLElement;
  const sidebar = document.getElementById('sidebar') as HTMLElement;

  function openDrawer() {
    sidebar.classList.add('open');
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    sidebar.classList.remove('open');
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  menuBtn?.addEventListener('click', openDrawer);
  overlay?.addEventListener('click', closeDrawer);

  // Chiudi drawer quando si clicca su un filtro pill (UX mobile)
  document.querySelectorAll('.sidebar-page-btn').forEach(btn => {
    btn.addEventListener('click', closeDrawer);
  });
</script>

<style>
  .layout {
    display: grid;
    grid-template-columns: 250px 1fr;
    grid-template-rows: 1fr auto;
    height: 100vh;
  }

  /* ── SIDEBAR OVERLAY (mobile) ── */
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 99;
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }
  .sidebar-overlay.open { display: block; }

  /* ── SIDEBAR ── */
  .sidebar {
    background: var(--bg2);
    border-right: 1px solid var(--border);
    position: sticky; top: 0;
    height: 100vh; overflow-y: auto;
    grid-column: 1;
    grid-row: 1 / -1;
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }

  .sidebar-inner {
    display: flex; flex-direction: column;
    padding: 1.75rem 1.25rem;
    height: 100%; gap: 1.5rem;
  }

  .brand {
    display: flex; align-items: center; gap: 0.85rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .brand-mark {
    font-family: var(--font-display);
    font-size: 0.85rem; font-weight: 800;
    letter-spacing: 0.08em;
    background: var(--text);
    color: var(--bg);
    padding: 0.3rem 0.5rem;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: 0.95rem; font-weight: 700;
    letter-spacing: 0.02em; color: var(--text);
  }

  .brand-sub {
    font-family: var(--font-mono); font-size: 0.6rem;
    text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--text3); margin-top: 0.1rem;
  }

  .db-stats { display: flex; flex-direction: column; gap: 0.75rem; }
  .db-stat { display: flex; flex-direction: column; gap: 0.1rem; }
  .db-n {
    font-family: var(--font-display);
    font-size: 1.8rem; font-weight: 800;
    color: var(--accent); line-height: 1; letter-spacing: -0.02em;
  }
  .db-l {
    font-family: var(--font-mono); font-size: 0.6rem;
    text-transform: uppercase; letter-spacing: 0.1em; color: var(--text3);
  }

  .filters { display: flex; flex-direction: column; gap: 1.25rem; flex: 1; }
  .filter-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .filter-label {
    font-family: var(--font-mono); font-size: 0.6rem;
    text-transform: uppercase; letter-spacing: 0.12em; color: var(--text3);
  }

  .filter-pills { display: flex; flex-wrap: wrap; gap: 0.35rem; }

  .pill {
    font-family: var(--font-mono); font-size: 0.68rem;
    padding: 0.3rem 0.65rem;
    border: 1px solid var(--border); background: transparent;
    color: var(--text2); cursor: pointer; border-radius: 2px;
    transition: all 0.12s;
  }
  .pill:hover { border-color: var(--text2); color: var(--text); }
  .pill.active { background: var(--text); color: var(--bg); border-color: var(--text); }

  .reset-filters {
    font-family: var(--font-mono); font-size: 0.65rem;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--text3); background: transparent;
    border: 1px solid var(--border);
    padding: 0.4rem 0.75rem; cursor: pointer; border-radius: 2px;
    transition: all 0.12s; align-self: flex-start; margin-top: auto;
  }
  .reset-filters:hover { color: var(--accent); border-color: var(--accent); }

  .sidebar-footer {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 0.4rem;
  }

  .sidebar-page-btn {
    font-family: var(--font-mono); font-size: 0.72rem;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--text2); text-decoration: none;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--border); border-radius: 3px;
    background: transparent; transition: all 0.15s; display: block;
  }
  .sidebar-page-btn:hover { color: var(--text); border-color: var(--text2); background: var(--bg3); }

  /* ── MOBILE MENU BTN (hidden on desktop) ── */
  .mobile-menu-btn {
    display: none;
    background: none;
    border: 1px solid var(--border);
    border-radius: 3px;
    cursor: pointer;
    padding: 0.4rem 0.65rem;
    font-size: 1.1rem;
    color: var(--text);
    line-height: 1;
    flex-shrink: 0;
    transition: border-color 0.15s;
  }
  .mobile-menu-btn:hover { border-color: var(--text2); }

  /* ── MAIN ── */
  .main {
    display: flex; flex-direction: column; gap: 1.25rem;
    padding: 1.75rem 2rem 1rem; min-width: 0;
    overflow-y: auto;
    grid-column: 2;
    grid-row: 1;
  }

  .topbar {
    display: flex; align-items: center; gap: 1rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .search-wrap {
    flex: 1; display: flex; align-items: center; gap: 0.6rem;
    background: var(--bg2); border: 1px solid var(--border);
    padding: 0 0.9rem; border-radius: 3px; transition: border-color 0.15s;
  }
  .search-wrap:focus-within { border-color: var(--text2); }
  .search-icon { color: var(--text3); font-size: 1rem; }
  .search-input {
    background: transparent; border: none; outline: none;
    font-family: var(--font-body); font-size: 0.88rem; color: var(--text);
    padding: 0.6rem 0; width: 100%;
  }
  .search-input::placeholder { color: var(--text3); }

  .sort-wrap { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }
  .sort-label {
    font-family: var(--font-mono); font-size: 0.65rem;
    text-transform: uppercase; letter-spacing: 0.1em; color: var(--text3);
  }
  .sort-select {
    font-family: var(--font-mono); font-size: 0.72rem;
    background: var(--bg2); border: 1px solid var(--border);
    color: var(--text); padding: 0.4rem 0.75rem;
    border-radius: 2px; cursor: pointer; outline: none;
  }
  .sort-select:focus { border-color: var(--text2); }

  .timeline { display: flex; flex-direction: column; gap: 1.5rem; }

  .year-group {
    border: 1px solid var(--border); border-radius: 4px;
    overflow: hidden; background: transparent; transition: all 0.15s;
  }
  .year-group.collapsed { border-color: var(--border); }
  .year-group.expanded { border-color: var(--text2); background: var(--bg2); }

  .year-header {
    width: 100%; display: flex; align-items: center; gap: 0.75rem;
    padding: 1rem 1.25rem; background: transparent; border: none;
    border-bottom: 1px solid var(--border); cursor: pointer;
    font-family: var(--font-display); font-size: 1.1rem;
    font-weight: 700; color: var(--text); text-align: left; transition: all 0.15s;
  }
  .year-group.expanded .year-header { border-bottom-color: var(--text2); background: rgba(255,255,255,0.02); }
  .year-header:hover { background: var(--bg2); }
  .year-chevron { display: inline-block; font-size: 0.72rem; color: var(--text2); transition: transform 0.2s; flex-shrink: 0; }
  .year-group.collapsed .year-chevron { transform: rotate(-90deg); }
  .year-label { flex: 1; }
  .year-count { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text3); flex-shrink: 0; }
  .year-races { display: flex; flex-direction: column; gap: 0.75rem; padding: 0.75rem 1rem; }

  .month-group {
    border: 1px solid var(--border); border-radius: 3px;
