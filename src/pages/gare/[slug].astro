---
import { formatData, formatDistanza, formatDislivello } from '../../lib/gare.js';

export async function getStaticPaths() {
  const garaFiles = import.meta.glob('../../../gare-sorgenti/dettagli/*.json', { eager: true });
  // @ts-ignore
  return Object.values(garaFiles).map(m => {
    const data = m.default ?? m;
    return { params: { slug: data.slug } };
  });
}

const { slug } = Astro.params;
const garaFiles = import.meta.glob('../../../gare-sorgenti/dettagli/*.json', { eager: true });
// @ts-ignore
let gara = Object.values(garaFiles).map(m => m.default ?? m).find(g => g.slug === slug);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
if (!gara) return Astro.redirect(`${base}/`);

const isCorsaATappe = gara.tipo === 'corsa_a_tappe';
const isTappa = gara.tipo === 'tappa';

// Per navigazione tra tappe: carica la corsa a tappe parent se necessario
let tappeDelleGara: any[] = [];
let indiceTappaCorrente = -1;
if (isTappa && gara.corsa_a_tappe_slug) {
  const corsaATabpeParent = Object.values(garaFiles)
    .map((m: any) => m.default ?? m)
    .find((g: any) => g.slug === gara.corsa_a_tappe_slug);
  if (corsaATabpeParent && corsaATabpeParent.tappe) {
    tappeDelleGara = [...corsaATabpeParent.tappe].sort((a: any, b: any) => (a.numero ?? 0) - (b.numero ?? 0));
    indiceTappaCorrente = tappeDelleGara.findIndex((t: any) => t.slug === slug);
  }
}

// Per il colore della top bar, genera colore solido o gradiente
const catColorMap = {
  'Elite':    '#C8A951',
  'U23':      '#4A7FA5',
  'Junior':   '#5C9E6E',
  'Allievi':  '#A0522D',
};
const categorie = Array.isArray(gara.categoria) ? gara.categoria : [gara.categoria];

// Colore del bordo: solido se singola categoria, gradiente se multiple
let borderColor = '';
if (categorie.length === 1) {
  borderColor = catColorMap[categorie[0]] ?? '#888';
} else {
  const colors = categorie.map(cat => catColorMap[cat] ?? '#888');
  borderColor = `linear-gradient(90deg, ${colors.join(', ')})`;
}

// Shade genere
const genereR = gara.genere === 'Femminile' ? '225,0,100' : '80,150,215';
const genereA1 = gara.genere === 'Femminile' ? '0.14' : '0.22';
const genereA2 = gara.genere === 'Femminile' ? '0.05' : '0.08';
const genereShade = `radial-gradient(ellipse 140px 52px at 260px 0%, rgba(${genereR},${genereA1}) 0%, rgba(${genereR},${genereA2}) 35%, transparent 65%)`;

// Per corse a tappe: ordina tappe per numero
const tappe = isCorsaATappe && gara.tappe
  ? [...gara.tappe].sort((a: any, b: any) => (a.numero ?? 0) - (b.numero ?? 0))
  : [];

// Per corse a tappe: navigazione tra anni della stessa serie
let yearNavigation: Array<{year: string; slug: string; isCurrent: boolean}> = [];
if (isCorsaATappe && gara.race_series) {
  const allRaces = Object.values(garaFiles)
    .map((m: any) => m.default ?? m)
    .filter((g: any) => g.tipo === 'corsa_a_tappe' && g.race_series === gara.race_series);
  
  const racesByYear: Record<string, any> = {};
  allRaces.forEach((race: any) => {
    const year = (race.data || race.data_inizio || '').split('-')[0];
    if (year && !racesByYear[year]) {
      racesByYear[year] = race;
    }
  });
  
  const years = Object.keys(racesByYear).sort((a, b) => parseInt(a) - parseInt(b));
  const currentYear = (gara.data || gara.data_inizio || '').split('-')[0];
  
  yearNavigation = years.map(year => ({
    year,
    slug: racesByYear[year].slug,
    isCurrent: year === currentYear
  }));
}

// Per singola tappa: link di ritorno alla corsa a tappe parent
const backHref = isTappa && gara.corsa_a_tappe_slug
  ? `${base}/gare/${gara.corsa_a_tappe_slug}/`
  : `${base}/`;
const backLabel = isTappa && gara.corsa_a_tappe_titolo
  ? `← ${gara.corsa_a_tappe_titolo}`
  : '← Race DB';

// Mappa disciplina → icona
const discIconMap: Record<string, string> = {
  'Strada':     '↗',
  'Criterium':  '⟳',
  'Cronometro': '⏱',
};
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{gara.titolo} — Race DB</title>
  <meta name="description" content={`${gara.titolo} - ${gara.luogo ?? ''} - ${isCorsaATappe ? gara.n_tappe + ' tappe' : (gara.distanza_km + 'km')}`} />
  
  <!-- Open Graph -->
  <meta property="og:title" content={`${gara.titolo} — Race DB`} />
  <meta property="og:type" content="website" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${gara.titolo} — Race DB`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  
  <style>
    :root {
      --bg:     #f5f2ed;
      --bg2:    #ffffff;
      --border: #c8c2b8;
      --text:   #0f0f0f;
      --text2:  #7a746b;
      --text3:  #aaa49e;
      --accent: #d4401a;
      --font-display: 'Barlow Condensed', sans-serif;
      --font-body:    'Barlow', sans-serif;
      --font-mono:    'DM Mono', monospace;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      height: 100vh;
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
    }

    /* ── TOP BAR ── */
    .top-bar {
      position: sticky; top: 0; z-index: 100;
      background: var(--bg2);
      border-bottom: none;
      display: flex; align-items: center;
      padding: 0 1.25rem; height: 52px; gap: 1rem;
      box-shadow: 0 1px 8px rgba(0,0,0,0.06);
      flex-shrink: 0;
    }
    .top-bar::after {
      content: '';
      position: absolute; bottom: 0; left: 0; right: 0;
      height: 2px;
      background: var(--cat-color, #888);
    }
    .back {
      font-family: var(--font-mono); font-size: 0.68rem;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--text3); text-decoration: none;
      display: flex; align-items: center; gap: 0.35rem;
      flex-shrink: 0; transition: color 0.15s;
      max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .back:hover { color: var(--accent); }
    .bar-divider { width: 1px; height: 20px; background: var(--border); flex-shrink: 0; }
    .bar-cat {
      font-family: var(--font-mono); font-size: 0.65rem;
      text-transform: uppercase; letter-spacing: 0.1em;
      flex-shrink: 0; display: flex; align-items: center; gap: 0.5rem;
    }
    .bar-cat-label { display: flex; align-items: center; gap: 0.25rem; }
    .genere-symbol { font-size: 0.75rem; color: var(--text3); text-transform: none; letter-spacing: 0; }
    .bar-title {
      font-family: var(--font-display);
      font-size: 1.1rem; font-weight: 700; letter-spacing: 0.01em;
      color: var(--text);
    }
    .bar-title-with-stages {
      display: flex; align-items: center; gap: 0.75rem;
      flex: 1; overflow: hidden;
    }
    .bar-stages {
      display: flex; align-items: center; gap: 0.35rem; flex-shrink: 0;
    }
    .bar-stages-links { display: flex; gap: 0.3rem; }
    .bar-stage-link {
      padding: 0.3rem 0.5rem; text-decoration: none; font-size: 0.7rem;
      font-weight: 600; color: var(--text3); transition: all 0.15s;
      cursor: pointer;
    }
    .bar-stage-link:hover { color: var(--accent); }
    .bar-stage-link.current {
      background: var(--accent); color: white; border-radius: 2px; padding: 0.3rem 0.5rem;
    }
    .bar-stats { display: flex; gap: 1.25rem; flex-shrink: 0; }
    .bstat { display: flex; flex-direction: column; align-items: flex-end; }
    .bstat-v { font-family: var(--font-mono); font-size: 0.82rem; font-weight: 500; color: var(--text); line-height: 1; }
    .bstat-l { font-family: var(--font-mono); font-size: 0.55rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text3); }

    /* ── GPX VIEWER ── */
    .report-frame { width: 100%; border: none; display: block; flex: 1; }

    /* ── STAGE RACE RECAP PAGE ── */
    .recap-body {
      flex: 1; overflow-y: auto;
      padding: 2rem 1.5rem;
      max-width: 860px; width: 100%; margin: 0 auto;
    }

    .recap-header {
      margin-bottom: 2rem;
    }
    .recap-hero-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 800; line-height: 1.05;
      letter-spacing: -0.01em;
      color: var(--text);
    }
    .recap-meta {
      display: flex; flex-wrap: wrap; gap: 1rem;
      margin-top: 0.75rem; align-items: center;
    }
    .recap-meta-item {
      font-family: var(--font-mono); font-size: 0.72rem;
      text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--text2);
    }
    .recap-totals {
      display: flex; gap: 2rem; flex-wrap: wrap;
      margin-top: 1.25rem; padding-top: 1.25rem;
      border-top: 1px solid var(--border);
    }
    .recap-total-block { display: flex; flex-direction: column; gap: 0.2rem; }
    .recap-total-v {
      font-family: var(--font-mono); font-size: 1.5rem; font-weight: 500;
      color: var(--text); line-height: 1;
    }
    .recap-total-l {
      font-family: var(--font-mono); font-size: 0.58rem;
      text-transform: uppercase; letter-spacing: 0.12em; color: var(--text3);
    }

    .stages-section { margin-top: 1.5rem; }
    .stages-heading {
      font-family: var(--font-mono); font-size: 0.65rem;
      text-transform: uppercase; letter-spacing: 0.12em;
      color: var(--text3); margin-bottom: 0.75rem;
    }
    .stages-list { display: flex; flex-direction: column; gap: 0; }

    .stage-card {
      display: flex; align-items: stretch;
      background: var(--bg2);
      border: 1px solid var(--border);
      margin-top: -1px;
      text-decoration: none; color: inherit;
      transition: transform 0.12s, box-shadow 0.12s, z-index 0s;
      position: relative; z-index: 0;
    }
    .stage-card:first-child { border-radius: 4px 4px 0 0; }
    .stage-card:last-child  { border-radius: 0 0 4px 4px; }
    .stage-card:only-child  { border-radius: 4px; }
    .stage-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.09); z-index: 1; }

    .stage-num {
      flex-shrink: 0; width: 56px;
      display: flex; align-items: center; justify-content: center;
      background: var(--bg);
      border-right: 1px solid var(--border);
      font-family: var(--font-display); font-size: 1.5rem; font-weight: 800;
      color: var(--text3);
    }

    .stage-info {
      flex: 1; padding: 0.9rem 1.1rem;
      display: flex; flex-direction: column; gap: 0.35rem;
    }
    .stage-name {
      font-family: var(--font-display); font-size: 1.15rem; font-weight: 700;
      color: var(--text); line-height: 1.2;
    }
    .stage-sub {
      display: flex; gap: 0.75rem; flex-wrap: wrap;
      font-family: var(--font-mono); font-size: 0.65rem;
      text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--text3);
    }
    .stage-stats {
      display: flex; gap: 1.1rem; margin-top: 0.25rem;
    }
    .stage-stat { display: flex; flex-direction: column; gap: 0.1rem; }
    .stage-stat-v { font-family: var(--font-mono); font-size: 0.82rem; font-weight: 500; color: var(--text); }
    .stage-stat-l { font-family: var(--font-mono); font-size: 0.55rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text3); }

    .stage-arrow {
      flex-shrink: 0; display: flex; align-items: center;
      padding: 0 1rem;
      font-family: var(--font-mono); font-size: 0.65rem;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--text3); transition: color 0.12s;
    }
    .stage-card:hover .stage-arrow { color: var(--accent); }

    /* Colore tappa in cima */
    .stage-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: var(--cat-color, #888);
    }

    /* Tappa senza GPX: stile dimmed */
    .stage-card--no-gpx { opacity: 0.65; pointer-events: none; }
    .stage-card--no-gpx .stage-arrow { display: none; }

    /* ── NAVIGAZIONE SERIE (anni) ── */
    .series-nav {
      margin-top: 2.5rem; padding-top: 2rem;
      border-top: 1px solid var(--border);
    }
    .series-nav-label {
      font-family: var(--font-mono); font-size: 0.65rem;
      text-transform: uppercase; letter-spacing: 0.12em;
      color: var(--text3); margin-bottom: 0.75rem;
    }
    .series-nav-links {
      display: flex; gap: 0.5rem; flex-wrap: wrap;
    }
    .series-nav-link {
      padding: 0.4rem 0.8rem;
      background: var(--bg2);
      border: 1px solid var(--border);
      color: var(--text2);
      text-decoration: none;
      font-family: var(--font-mono); font-size: 0.72rem;
      font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.05em;
      border-radius: 3px;
      transition: all 0.15s;
      cursor: pointer;
    }
    .series-nav-link:hover {
      color: var(--accent);
      border-color: var(--accent);
      background: rgba(212, 64, 26, 0.02);
    }
    .series-nav-link.current {
      background: var(--accent);
      color: white;
      border-color: var(--accent);
    }

    @media (max-width: 600px) {
      .bar-stats { display: none; }
      .bar-cat { display: none; }
      .bar-divider:not(:first-of-type) { display: none; }
      .bar-stages { display: none; }
      .recap-body { padding: 1.25rem 1rem; }
      .recap-totals { gap: 1.25rem; }
    }
  </style>
</head>
<body>
  <!-- ── TOP BAR (comune a tutti i tipi) ────────────────────────────────── -->
  <div class="top-bar" style={{
    "--cat-color": borderColor,
    "backgroundImage": genereShade,
    "backgroundColor": "var(--bg2)"
  }}>
    <a href={backHref} class="back">{backLabel}</a>
    <div class="bar-divider"></div>
    <span class="bar-cat">
      <span class="bar-cat-label">
        {categorie.map((cat: string, idx: number) => (
          <span style={{ color: catColorMap[cat as keyof typeof catColorMap] ?? '#888', fontWeight: 500 }}>
            {cat}{idx < categorie.length - 1 ? ' / ' : ''}
          </span>
        ))}
        {isCorsaATappe
          ? <span style="color:var(--text3)"> · {gara.n_tappe} tappe</span>
          : <span style="color:var(--text3)"> · {gara.disciplina}</span>
        }
      </span>
      <span class="genere-symbol">{gara.genere === 'Femminile' ? '♀' : '♂'}</span>
    </span>
    <div class="bar-divider"></div>
    <div class="bar-title-with-stages">
      <span class="bar-title">{gara.titolo}</span>
      {isTappa && tappeDelleGara.length > 0 && (
        <div class="bar-stages">
          <div class="bar-stages-links">
            {tappeDelleGara.map((t: any) => (
              <a
                href={`${base}/gare/${t.slug}/`}
                class={`bar-stage-link ${slug === t.slug ? 'current' : ''}`}
                title={`${t.nome} (${t.distanza_km} km)`}
              >
                S{t.numero}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
    <div class="bar-stats">
      {gara.distanza_km && (
        <div class="bstat">
          <span class="bstat-v">{formatDistanza(gara.distanza_km)}</span>
          <span class="bstat-l">{isCorsaATappe ? 'tot dist' : 'dist'}</span>
        </div>
      )}
      {gara.dislivello_m && (
        <div class="bstat">
          <span class="bstat-v">{formatDislivello(gara.dislivello_m)}</span>
          <span class="bstat-l">{isCorsaATappe ? 'tot D+' : 'D+'}</span>
        </div>
      )}
      {(gara.data_inizio || gara.data) && (
        <div class="bstat">
          <span class="bstat-v">
            {isCorsaATappe && gara.data_fine
              ? `${formatData(gara.data_inizio || gara.data)} – ${formatData(gara.data_fine)}`
              : formatData(gara.data_inizio || gara.data)}
          </span>
          <span class="bstat-l">data</span>
        </div>
      )}
    </div>
  </div>

  {isCorsaATappe ? (
    <!-- ── RECAP PAGE: corsa a tappe ─────────────────────────────────────── -->
    <div class="recap-body">
      <div class="recap-header">
        <h1 class="recap-hero-title">{gara.titolo}</h1>
        <div class="recap-meta">
          {gara.luogo && <span class="recap-meta-item">↗ {gara.luogo}</span>}
          {(gara.data_inizio || gara.data) && (
            <span class="recap-meta-item">
              {isCorsaATappe && gara.data_fine
                ? `${formatData(gara.data_inizio || gara.data)} – ${formatData(gara.data_fine)}`
                : formatData(gara.data_inizio || gara.data)}
            </span>
          )}
          {gara.genere && <span class="recap-meta-item">{gara.genere}</span>}
        </div>
        <div class="recap-totals">
          <div class="recap-total-block">
            <span class="recap-total-v">{gara.n_tappe}</span>
            <span class="recap-total-l">tappe</span>
          </div>
          {gara.distanza_km && (
            <div class="recap-total-block">
              <span class="recap-total-v">{formatDistanza(gara.distanza_km)}</span>
              <span class="recap-total-l">distanza totale</span>
            </div>
          )}
          {gara.dislivello_m && (
            <div class="recap-total-block">
              <span class="recap-total-v">{formatDislivello(gara.dislivello_m)}</span>
              <span class="recap-total-l">dislivello totale</span>
            </div>
          )}
        </div>
      </div>

      <div class="stages-section">
        <div class="stages-heading">Tappe</div>
        <div class="stages-list">
          {tappe.map((tappa: any) => {
            const hasGpx = true; // Il link è sempre attivo; senza GPX il viewer non mostrerà la mappa
            return (
              <a
                href={`${base}/gare/${tappa.slug}/`}
                class="stage-card"
                style={`--cat-color: ${borderColor}`}
              >
                <div class="stage-num">{tappa.numero}</div>
                <div class="stage-info">
                  <div class="stage-name">{tappa.nome}</div>
                  <div class="stage-sub">
                    {tappa.data && <span>{formatData(tappa.data)}</span>}
                    {tappa.disciplina && <span>{discIconMap[tappa.disciplina] ?? '·'} {tappa.disciplina}</span>}
                  </div>
                  <div class="stage-stats">
                    {tappa.distanza_km && (
                      <div class="stage-stat">
                        <span class="stage-stat-v">{formatDistanza(tappa.distanza_km)}</span>
                        <span class="stage-stat-l">dist</span>
                      </div>
                    )}
                    {tappa.dislivello_m && (
                      <div class="stage-stat">
                        <span class="stage-stat-v">{formatDislivello(tappa.dislivello_m)}</span>
                        <span class="stage-stat-l">D+</span>
                      </div>
                    )}
                  </div>
                </div>
                <div class="stage-arrow">Apri →</div>
              </a>
            );
          })}
        </div>
      </div>

      {yearNavigation.length > 1 && (
        <div class="series-nav">
          <div class="series-nav-label">Edizione</div>
          <div class="series-nav-links">
            {yearNavigation.map((nav) => (
              <a
                href={`${base}/gare/${nav.slug}/`}
                class={`series-nav-link ${nav.isCurrent ? 'current' : ''}`}
              >
                {nav.year}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  ) : (
    <!-- ── GPX VIEWER (gara normale o singola tappa) ─────────────────────── -->
    <>
      <iframe class="report-frame" src={`${base}/gara.html?gara=${slug}`} title={gara.titolo}></iframe>
    </>
  )}


</body>
</html>
