---
import { formatData, formatDistanza, formatDislivello } from '../../lib/gare.js';

export async function getStaticPaths() {
  const garaFiles = import.meta.glob('../../../gare-sorgenti/dettagli/*.json', { eager: true });
  // @ts-ignore
  return Object.values(garaFiles).map(m => {
    const data = m.default ?? m;
    return { params: { slug: data.slug } };
  });
}

const { slug } = Astro.params;
const garaFiles = import.meta.glob('../../../gare-sorgenti/dettagli/*.json', { eager: true });
// @ts-ignore
let gara = Object.values(garaFiles).map(m => m.default ?? m).find(g => g.slug === slug);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
if (!gara) return Astro.redirect(`${base}/`);

// Controlla se esiste un file GPX per questa gara (non più necessario ma manteniamo per futurità)
const gpxFiles = import.meta.glob('../../../gare-sorgenti/gpx/*-gpx.json', { eager: false });
const gpxSlug = (gara.gpx_reference ?? slug);

// Per il colore della top bar, genera colore solido o gradiente
const catColorMap = {
  'Elite':    '#C8A951',
  'U23':      '#4A7FA5',
  'Junior':   '#5C9E6E',
  'Allievi':  '#A0522D',
};
const categorie = Array.isArray(gara.categoria) ? gara.categoria : [gara.categoria];

// Colore del testo: sempre il primo (solido)
const textColor = catColorMap[categorie[0]] ?? '#888';

// Colore del bordo: solido se singola categoria, gradiente se multiple
let borderColor = '';
if (categorie.length === 1) {
  borderColor = catColorMap[categorie[0]] ?? '#888';
} else {
  const colors = categorie.map(cat => catColorMap[cat] ?? '#888');
  borderColor = `linear-gradient(90deg, ${colors.join(', ')})`;
}

// Shade genere — identica a GaraCard: radiale dall'angolo alto-dx
// Centrata sull'area del badge (dopo "← Race DB | "), picco a ~250px dal left
const genereR = gara.genere === 'Femminile' ? '225,0,100' : '80,150,215';
const genereA1 = gara.genere === 'Femminile' ? '0.14' : '0.22';
const genereA2 = gara.genere === 'Femminile' ? '0.05' : '0.08';
const genereShade = `radial-gradient(ellipse 140px 52px at 260px 0%, rgba(${genereR},${genereA1}) 0%, rgba(${genereR},${genereA2}) 35%, transparent 65%)`;
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{gara.titolo} — Race DB</title>
  <meta name="description" content={`${gara.titolo} - ${gara.luogo} - ${gara.distanza_km}km`} />
  
  <!-- Open Graph -->
  <meta property="og:title" content={`${gara.titolo} — Race DB`} />
  <meta property="og:description" content={`${gara.titolo} - ${gara.luogo} - ${gara.distanza_km}km`} />
  <meta property="og:type" content="website" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${gara.titolo} — Race DB`} />
  <meta name="twitter:description" content={`${gara.titolo} - ${gara.luogo} - ${gara.distanza_km}km`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  
  <style>
    :root {
      --bg:     #f5f2ed;
      --bg2:    #ffffff;
      --border: #c8c2b8;
      --text:   #0f0f0f;
      --text2:  #7a746b;
      --text3:  #aaa49e;
      --accent: #d4401a;
      --font-display: 'Barlow Condensed', sans-serif;
      --font-body:    'Barlow', sans-serif;
      --font-mono:    'DM Mono', monospace;
    }
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    body {
      height: 100vh;
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
    }

    .top-bar {
      position: sticky; top: 0; z-index: 100;
      background: var(--bg2);
      border-bottom: none;
      display: flex; align-items: center;
      padding: 0 1.25rem; height: 52px; gap: 1rem;
      box-shadow: 0 1px 8px rgba(0,0,0,0.06);
      flex-shrink: 0;
    }

    .top-bar::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--cat-color, #888);
    }

    .back {
      font-family: var(--font-mono); font-size: 0.68rem;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--text3); text-decoration: none;
      display: flex; align-items: center; gap: 0.35rem;
      flex-shrink: 0; transition: color 0.15s;
    }
    .back:hover { color: var(--accent); }

    .bar-divider { width: 1px; height: 20px; background: var(--border); flex-shrink: 0; }

    .bar-cat {
      font-family: var(--font-mono); font-size: 0.65rem;
      text-transform: uppercase; letter-spacing: 0.1em;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .bar-cat-label {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    .genere-symbol {
      font-size: 0.75rem;
      color: var(--text3);
      text-transform: none;
      letter-spacing: 0;
    }

    .bar-title {
      font-family: var(--font-display);
      font-size: 1.1rem; font-weight: 700; letter-spacing: 0.01em;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      flex: 1; color: var(--text);
    }

    .bar-stats { display: flex; gap: 1.25rem; flex-shrink: 0; }
    .bstat { display: flex; flex-direction: column; align-items: flex-end; }
    .bstat-v { font-family: var(--font-mono); font-size: 0.82rem; font-weight: 500; color: var(--text); line-height: 1; }
    .bstat-l { font-family: var(--font-mono); font-size: 0.55rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text3); }

    .report-frame { width: 100%; border: none; display: block; flex: 1; }
    
    .content-wrapper {
      flex: 1;
      overflow-y: auto;
      padding: 1rem;
    }

    @media (max-width: 600px) {
      .bar-stats { display: none; }
      .bar-cat { display: none; }
      .bar-divider:not(:first-of-type) { display: none; }
    }
  </style>
</head>
<body>
  <div class="top-bar" style={{
    "--cat-color": borderColor,
    "backgroundImage": genereShade,
    "backgroundColor": "var(--bg2)"
  }}>
    <a href={`${base}/`} class="back">← Race DB</a>
    <div class="bar-divider"></div>
    <span class="bar-cat">
      <span class="bar-cat-label">
        {categorie.map((cat, idx) => (
          <span key={idx} style={{ color: catColorMap[cat] ?? '#888', fontWeight: 500 }}>
            {cat}{idx < categorie.length - 1 ? ' / ' : ''}
          </span>
        ))}
        {' · '}{gara.disciplina}
      </span>
      <span class="genere-symbol">{gara.genere === 'Femminile' ? '♀' : '♂'}</span>
    </span>
    <div class="bar-divider"></div>
    <span class="bar-title">{gara.titolo}</span>
    <div class="bar-stats">
      {gara.distanza_km && (
        <div class="bstat">
          <span class="bstat-v">{formatDistanza(gara.distanza_km)}</span>
          <span class="bstat-l">dist</span>
        </div>
      )}
      {gara.dislivello_m && (
        <div class="bstat">
          <span class="bstat-v">{formatDislivello(gara.dislivello_m)}</span>
          <span class="bstat-l">D+</span>
        </div>
      )}
      {gara.data && (
        <div class="bstat">
          <span class="bstat-v">{formatData(gara.data)}</span>
          <span class="bstat-l">data</span>
        </div>
      )}
    </div>
  </div>

  <iframe class="report-frame" src={`${base}/gara.html?gara=${slug}`} title={gara.titolo}></iframe>
</body>
</html>