---
import Base from '../layouts/Base.astro';
import LangSwitcher from '../components/LangSwitcher.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const faqs_it = [
  {
    q: "Come si aggiunge una gara al database?",
    a: "Scrivimi allegando il file .gpx della gara. Includi nel messaggio più info possibili: nome della gara, data, luogo, categoria (Elite / U23 / Junior / Allievi), disciplina e genere. Provvedo ad aggiungerla il prima possibile."
  },
  {
    q: "I dati sono ufficiali?",
    a: "No. I dati vengono estratti automaticamente dai file .gpx, raccolti da fonti pubbliche o contribuiti da utenti. Quindi potrebbero esserci errori o imprecisioni. Se noti qualcosa che non va, segnalami e vedo di correggerlo."
  },
  {
    q: "Come funziona Street View?",
    a: "Clic destro su qualsiasi punto del tracciato apre Google Street View in una nuova scheda, centrato esattamente su quella coordinata GPS. Non è un'integrazione embedded — per quella servirebbero le API Google a pagamento — ma funziona perfettamente per esplorare il percorso in anticipo. Su mobile invece devi tenere premuto sulla mappa"
  },
  {
    q: "Su telefono non va così bene",
    a: "Già... in generale è fruibile, ma consiglio di guardare tutto da PC"
  },
  {
    q: "Come vengono rilevate le salite?",
    a: "Le salite vengono rilevate automaticamente secondo un algoritmo basato su: pendenza, lunghezza, dislivello e continuità. Non è perfetto, essendo un rilevamento automatico, ma in generale funziona abbastanza bene. Se noti errori evidenti, segnala e vedo di correggerli."
  },
  {
    q: "Il sito è gratuito?",
    a: "Sì, completamente. Nessun accesso a pagamento, nessuna registrazione, nessuna pubblicità. Se lo trovi utile e vuoi sostenere il progetto, puoi offrire un caffè su Ko-fi, ma non è in alcun modo obbligatorio."
  },
  {
    q: "Come segnalo un errore su una gara?",
    a: "Scrivimi indicando il nome della gara e il dato errato — distanza, dislivello, data, categoria o altro. Correggo il prima possibile."
  },
  {
    q: "Perché ci sono solo gare giovanili?",
    a: "Per le categorie Elite e Pro esiste già di tutto online, PCS ecc. Per il ciclismo giovanile non c'è praticamente nulla di organizzato. L'archivio nasce proprio per colmare questo vuoto, anche se nel tempo potrebbero aggiungersi gare di altre categorie."
  },
  {
    q: "Posso scaricare il file GPX di una gara?",
    a: "No. Se hai bisogno del file di una gara specifica, contattami e vediamo come procedere."
  },
  {
    q: "Posso farmi allenare da te?",
    a: "Sì. Sono un preparatore atletico e sport scientist, lavoro con ciclisti di diverse categorie. Se ti interessa, scrivi a bonvicin.coaching@gmail.com o controlla il Linktree. Poi, valutiamo insieme."
  },
  {
    q: "Hai altri strumenti o servizi online?",
    a: "Certo, trovi molto altro sul mio Linktree. Considera che sono un preparatore, non un software developer."
  },
  {
    q: "Questo archivio è sotto licenza?",
    a: "Si, AGPL-3.0. Se vuoi contribuire o usare i dati in qualche modo, contattami e ne parliamo."
  },
  {
    q: "Perchè non usare Veloviewer?",
    a: "Perché sono due cose diverse. E perché mi piace arrangiarmi e poter modificare i tool come voglio."
  },
];

const faqs_en = [
  {
    q: "How do I add a race to the database?",
    a: "Write to me attaching the .gpx file of the race. Include as much info as possible: race name, date, location, category, discipline. I'll add it as soon as possible."
  },
  {
    q: "Are the data official?",
    a: "No. The data is automatically extracted from .gpx files, collected from public sources or contributed by users. Therefore, there might be errors or inaccuracies. If you notice anything that's wrong, let me know and I'll look into fixing it."
  },
  {
    q: "How does Street View work?",
    a: "Right-clicking on any point of the route opens Google Street View in a new tab, centred exactly on that GPS coordinate. It's not an embedded integration — that would require paid Google APIs — but it works perfectly for exploring the route in advance. On mobile you need to long-press on the map instead."
  },
  {
    q: "It doesn't work that well on mobile",
    a: "True... it's generally usable, but I recommend viewing everything on a PC."
  },
  {
    q: "How are climbs detected?",
    a: "Climbs are detected automatically using an algorithm based on: gradient, length, elevation gain and continuity. It's not perfect, being an automatic detection, but it generally works well enough. If you notice obvious errors, let me know and I'll look into fixing them."
  },
  {
    q: "Is the site free?",
    a: "Yes, completely. No paid access, no registration, no ads. If you find it useful and want to support the project, you can buy me a coffee on Ko-fi, but it's in no way required."
  },
  {
    q: "How do I report an error on a race?",
    a: "Write to me indicating the race name and the incorrect data — distance, elevation, date, category or anything else. I'll fix it as soon as possible."
  },
  {
    q: "Why are there only youth races?",
    a: "For Elite and Pro categories there's already plenty online, PCS etc. For youth cycling there's practically nothing organised. The archive was created precisely to fill this gap, although races from other categories may be added over time."
  },
  {
    q: "Can I download the GPX file of a race?",
    a: "No. If you need the file for a specific race, contact me and we'll figure out how to proceed."
  },
  {
    q: "Can I get coached by you?",
    a: "Yes. I'm a cycling coach and sport scientist, I work with cyclists across different categories. If you're interested, write to bonvicin.coaching@gmail.com or check the Linktree. Then, we'll evaluate together."
  },
  {
    q: "Do you have other tools or online services?",
    a: "Sure, you'll find much more on my Linktree. Bear in mind I'm a coach, not a software developer."
  },
  {
    q: "Is this archive under a licence?",
    a: "Yes, AGPL-3.0. If you want to contribute or use the data in any way, contact me and we'll talk."
  },
  {
    q: "Why not use Veloviewer?",
    a: "Because they're two different things. And because I like figuring things out myself and being able to modify the tools however I want."
  },
];
---

<Base title="FAQ — Race Database by Bonvi">
<div class="page-layout">

  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-inner">
      <div class="brand">
        <div class="brand-mark">BRD</div>
        <div>
          <div class="brand-name">Race Database</div>
          <div class="brand-sub">Easy</div>
        </div>
      </div>
      <nav class="sidebar-nav">
        <a href={`${base}/`} class="nav-btn">Prossime Gare</a>
        <a href={`${base}/archivio`} class="nav-btn">Archivio</a>
        <a href={`${base}/progetto`} class="nav-btn">Il Progetto</a>
        <a href={`${base}/faq`} class="nav-btn active">FAQ</a>
        <a href={`${base}/contattami`} class="nav-btn">Contattami</a>
      </nav>
    </div>
  </aside>

  <main class="main">

    <div class="mobile-topbar">
      <button class="mobile-menu-btn" id="menu-btn" aria-label="Apri menu">☰</button>
      <LangSwitcher />
    </div>

    <div class="page-content">

      <header class="page-header">
        <div class="page-tag" data-i18n="tag">Domande frequenti</div>
        <h1 class="page-title">FAQ</h1>
        <p class="page-lead" id="page-lead">Le domande che mi vengono fatte più spesso — se non trovi quello che cerchi, <a href={`${base}/contattami`}>scrivimi</a>.</p>
      </header>

      <div class="faq-list" id="faq-list-it">
        {faqs_it.map((item, i) => (
          <details class="faq-item" name="faq-it">
            <summary class="faq-question">
              <span class="faq-n">{String(i + 1).padStart(2, '0')}</span>
              <span class="faq-q-text">{item.q}</span>
              <span class="faq-chevron">▼</span>
            </summary>
            <div class="faq-answer">
              <p>{item.a}</p>
            </div>
          </details>
        ))}
      </div>

      <div class="faq-list" id="faq-list-en" style="display:none">
        {faqs_en.map((item, i) => (
          <details class="faq-item" name="faq-en">
            <summary class="faq-question">
              <span class="faq-n">{String(i + 1).padStart(2, '0')}</span>
              <span class="faq-q-text">{item.q}</span>
              <span class="faq-chevron">▼</span>
            </summary>
            <div class="faq-answer">
              <p>{item.a}</p>
            </div>
          </details>
        ))}
      </div>

      <div class="faq-cta">
        <p data-i18n="cta_text">Non hai trovato risposta?</p>
        <a href={`${base}/contattami`} class="cta-btn" data-i18n="cta_btn">Contattami →</a>
      </div>

    </div>
  </main>

  <footer>
    <a href="https://linktr.ee/bonvicin.coaching" target="_blank">
      &copy; 2026 Andrea Bonvicin — BRD Race Database — Licenza AGPL v3
    </a>
  </footer>

</div>
</Base>

<script>
  const menuBtn = document.getElementById('menu-btn') as HTMLElement;
  const overlay = document.getElementById('sidebar-overlay') as HTMLElement;
  const sidebar = document.getElementById('sidebar') as HTMLElement;

  function openDrawer() { sidebar.classList.add('open'); overlay.classList.add('open'); document.body.style.overflow = 'hidden'; }
  function closeDrawer() { sidebar.classList.remove('open'); overlay.classList.remove('open'); document.body.style.overflow = ''; }

  menuBtn?.addEventListener('click', openDrawer);
  overlay?.addEventListener('click', closeDrawer);
  document.querySelectorAll('.nav-btn').forEach(btn => btn.addEventListener('click', closeDrawer));

  // i18n
  const lang = localStorage.getItem('brd-lang') || 'it';
  if (lang === 'en') {
    (document.getElementById('faq-list-it') as HTMLElement).style.display = 'none';
    (document.getElementById('faq-list-en') as HTMLElement).style.display = '';
    const t: Record<string, string> = {
      tag: 'Frequently asked questions',
      cta_text: "Didn't find an answer?",
      cta_btn: 'Contact me →',
    };
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
      const key = el.dataset.i18n!;
      if (t[key]) el.textContent = t[key];
    });
    const lead = document.getElementById('page-lead');
    if (lead) lead.innerHTML = `The questions I get asked most often — if you can't find what you're looking for, <a href="${window.location.pathname.replace('/faq','')}/contattami">write to me</a>.`;
  }
</script>

<style>
  .page-layout {
    display: grid;
    grid-template-columns: 250px 1fr;
    grid-template-rows: 1fr auto;
    min-height: 100vh;
  }

  .sidebar-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 99;
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }
  .sidebar-overlay.open { display: block; }

  .sidebar {
    background: var(--bg2);
    border-right: 1px solid var(--border);
    position: sticky; top: 0;
    height: 100vh; overflow-y: auto;
    grid-row: 1 / 2;
  }

  .sidebar-inner { display: flex; flex-direction: column; padding: 1.75rem 1.25rem; height: 100%; gap: 1.5rem; }

  .brand { display: flex; align-items: center; gap: 0.85rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
  .brand-mark { font-family: var(--font-display); font-size: 0.85rem; font-weight: 800; letter-spacing: 0.08em; background: var(--text); color: var(--bg); padding: 0.3rem 0.5rem; border-radius: 2px; flex-shrink: 0; }
  .brand-name { font-family: var(--font-display); font-size: 1rem; font-weight: 700; letter-spacing: 0.02em; line-height: 1.1; }
  .brand-sub { font-family: var(--font-mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text3); margin-top: 0.15rem; }

  .sidebar-nav { display: flex; flex-direction: column; gap: 0.4rem; }
  .nav-btn { font-family: var(--font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text2); text-decoration: none; padding: 0.6rem 0.75rem; border: 1px solid var(--border); border-radius: 3px; background: transparent; transition: all 0.15s; display: block; }
  .nav-btn:hover { color: var(--text); border-color: var(--text2); background: var(--bg3); }
  .nav-btn.active { color: var(--accent); border-color: var(--accent); background: rgba(212, 64, 26, 0.05); }

  /* ── Mobile topbar ── */
  .mobile-topbar { display: none; }
  .mobile-menu-btn {
    background: none; border: 1px solid var(--border); border-radius: 3px;
    cursor: pointer; padding: 0.4rem 0.65rem; font-size: 1.1rem;
    color: var(--text); line-height: 1; transition: border-color 0.15s;
  }
  .mobile-menu-btn:hover { border-color: var(--text2); }

  .main { padding: 3rem 3.5rem; max-width: 720px; }
  .page-content { display: flex; flex-direction: column; gap: 3rem; }

  .page-header { border-bottom: 1px solid var(--border); padding-bottom: 2rem; }
  .page-tag { font-family: var(--font-mono); font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--accent); margin-bottom: 0.75rem; }
  .page-title { font-family: var(--font-display); font-size: 2.8rem; font-weight: 800; letter-spacing: 0.01em; line-height: 1; margin-bottom: 1rem; color: var(--text); }
  .page-lead { font-size: 1.05rem; color: var(--text2); line-height: 1.6; }
  .page-lead a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }

  .faq-list { display: flex; flex-direction: column; gap: 0; border: 1px solid var(--border); border-radius: 4px; overflow: hidden; }
  .faq-item { border-bottom: 1px solid var(--border); }
  .faq-item:last-child { border-bottom: none; }
  .faq-question { display: flex; align-items: center; gap: 1rem; padding: 1.1rem 1.25rem; cursor: pointer; list-style: none; background: var(--bg2); transition: background 0.15s; user-select: none; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question:hover { background: var(--bg3); }
  .faq-item[open] .faq-question { background: var(--bg3); border-bottom: 1px solid var(--border); }
  .faq-n { font-family: var(--font-mono); font-size: 0.6rem; color: var(--accent); letter-spacing: 0.1em; flex-shrink: 0; width: 1.5rem; }
  .faq-q-text { font-family: var(--font-display); font-size: 1rem; font-weight: 700; letter-spacing: 0.02em; color: var(--text); flex: 1; }
  .faq-chevron { font-size: 0.65rem; color: var(--text3); flex-shrink: 0; transition: transform 0.2s; }
  .faq-item[open] .faq-chevron { transform: rotate(180deg); }
  .faq-answer { padding: 1.1rem 1.25rem 1.1rem calc(1.25rem + 1rem + 1.5rem); background: var(--bg); }
  .faq-answer p { font-size: 0.9rem; line-height: 1.75; color: var(--text2); }

  .faq-cta { display: flex; align-items: center; gap: 1.25rem; padding-top: 0.5rem; border-top: 1px solid var(--border); }
  .faq-cta p { font-size: 0.88rem; color: var(--text2); }
  .cta-btn { font-family: var(--font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.75rem 1.25rem; border-radius: 3px; text-decoration: none; background: var(--text); color: var(--bg); border: 1px solid var(--text); transition: all 0.15s; display: inline-block; }
  .cta-btn:hover { background: var(--accent); border-color: var(--accent); }

  footer { grid-column: 1 / -1; grid-row: 2; text-align: center; padding: 1rem 1.25rem; background: var(--bg2); color: var(--text2); font-size: 0.8rem; border-top: 1px solid var(--border); flex-shrink: 0; }
  footer a { color: var(--text2); text-decoration: none; font-weight: 500; transition: color 0.2s; }
  footer a:hover { color: var(--accent); }

  @media (max-width: 768px) {
    .page-layout { grid-template-columns: 1fr; }

    .mobile-topbar { display: flex; align-items: center; padding: 0.75rem 1rem; border-bottom: 1px solid var(--border); background: var(--bg); position: sticky; top: 0; z-index: 10; margin-bottom: 1.5rem; }

    .sidebar {
      position: fixed !important;
      top: 0; left: 0;
      height: 100dvh !important;
      width: 285px;
      z-index: 100;
      transform: translateX(-100%);
      box-shadow: none;
      overflow-y: auto;
    }
    .sidebar.open { transform: translateX(0); box-shadow: 4px 0 32px rgba(0,0,0,0.18); }
    .sidebar-inner { height: auto; min-height: 100%; padding-bottom: calc(1.25rem + env(safe-area-inset-bottom, 1rem)); }

    .main { padding: 0 1rem calc(1.5rem + env(safe-area-inset-bottom, 0.5rem)); }
    .page-title { font-size: 2rem; }
    .faq-answer { padding-left: 1.25rem; }
  }
</style>