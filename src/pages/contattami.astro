---
import Base from '../layouts/Base.astro';
import LangSwitcher from '../components/LangSwitcher.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Contattami — Race Database by Bonvi">
<div class="page-layout">

  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-inner">
      <div class="brand">
        <div class="brand-mark">BRD</div>
        <div>
          <div class="brand-name">Race Database</div>
          <div class="brand-sub">Easy</div>
        </div>
      </div>
      <nav class="sidebar-nav">
        <a href={`${base}/`} class="nav-btn">Prossime Gare</a>
        <a href={`${base}/archivio`} class="nav-btn">Archivio</a>
        <a href={`${base}/bmap`} class="nav-btn">BMAP</a>
        <a href={`${base}/progetto`} class="nav-btn">Il Progetto</a>
        <a href={`${base}/faq`} class="nav-btn">FAQ</a>
        <a href={`${base}/contattami`} class="nav-btn active">Contattami</a>
      </nav>
    </div>
  </aside>

  <main class="main">

    <div class="mobile-topbar">
      <button class="mobile-menu-btn" id="menu-btn" aria-label="Apri menu">☰</button>
      <LangSwitcher />
    </div>

    <div class="page-content">

      <header class="page-header">
        <div class="page-tag" data-i18n="tag">Contatti</div>
        <h1 class="page-title" data-i18n="title">Contattami</h1>
        <p class="page-lead" id="page-lead">Scrivi a <a href="mailto:bonvicin.coaching@gmail.com">bonvicin.coaching@gmail.com</a> — trovi qui sotto cosa includere a seconda del motivo.</p>
      </header>

      <section class="section">
        <h2 class="section-title" data-i18n="why_title">Perché scrivere</h2>
        <div class="reasons-grid">

          <div class="reason-card">
            <div class="reason-icon">⊕</div>
            <div class="reason-title" data-i18n="r1_title">Aggiungi una gara</div>
            <p class="reason-desc" data-i18n="r1_desc">Allega il file <strong>.gpx</strong> e indica: nome della gara, data, luogo, categoria (Elite / U23 / Junior / Allievi), disciplina (Strada / Criterium / Cronometro) e genere (Maschile / Femminile).</p>
          </div>

          <div class="reason-card">
            <div class="reason-icon">✎</div>
            <div class="reason-title" data-i18n="r2_title">Segnala un errore</div>
            <p class="reason-desc" data-i18n="r2_desc">Indica il nome della gara e il dato errato — distanza, dislivello, data o altro. Correggo il prima possibile. Considera che distanze e dislivelli sono calcolati automaticamente, quindi potrebbero non essere perfettamente corretti.</p>
          </div>

          <div class="reason-card">
            <div class="reason-icon">◎</div>
            <div class="reason-title" data-i18n="r3_title">Farsi allenare</div>
            <p class="reason-desc" data-i18n="r3_desc">Sono un preparatore atletico e sport scientist. Raccontami il tuo livello, i tuoi obiettivi e il calendario che hai in mente — vediamo se possiamo lavorare insieme.</p>
          </div>

          <div class="reason-card">
            <div class="reason-icon">◇</div>
            <div class="reason-title" data-i18n="r4_title">Qualsiasi altra cosa</div>
            <p class="reason-desc" data-i18n="r4_desc">Suggerimenti, feedback, domande, o semplicemente vuoi parlare di ciclismo e preparazione. Va bene tutto.</p>
          </div>

        </div>
      </section>

      <div class="mail-cta">
        <a href="mailto:bonvicin.coaching@gmail.com" class="mail-btn" data-i18n="mail_btn">
          Scrivi una mail →
        </a>
        <a href="https://linktr.ee/bonvicin.coaching" target="_blank" rel="noopener" class="mail-btn mail-btn--secondary">
          Linktree
        </a>
        <a href="https://ko-fi.com/andreabonvicin" target="_blank" rel="noopener" class="mail-btn mail-btn--kofi">
          ☕ <span data-i18n="kofi_btn">Sostieni</span>
        </a>
      </div>

    </div>
  </main>

  <footer>
    <a href="https://linktr.ee/bonvicin.coaching" target="_blank">
      &copy; 2026 Andrea Bonvicin — BRD Race Database — Licenza AGPL v3
    </a>
  </footer>

</div>
</Base>

<script>
  const menuBtn = document.getElementById('menu-btn') as HTMLElement;
  const overlay = document.getElementById('sidebar-overlay') as HTMLElement;
  const sidebar = document.getElementById('sidebar') as HTMLElement;

  function openDrawer() { sidebar.classList.add('open'); overlay.classList.add('open'); document.body.style.overflow = 'hidden'; }
  function closeDrawer() { sidebar.classList.remove('open'); overlay.classList.remove('open'); document.body.style.overflow = ''; }

  menuBtn?.addEventListener('click', openDrawer);
  overlay?.addEventListener('click', closeDrawer);
  document.querySelectorAll('.nav-btn').forEach(btn => btn.addEventListener('click', closeDrawer));

  // i18n
  const lang = localStorage.getItem('brd-lang') || 'it';
  if (lang === 'en') {
    const t: Record<string, string> = {
      tag: 'Contact',
      title: 'Contact me',
      why_title: 'Why write',
      r1_title: 'Add a race',
      r1_desc: 'Attach the <strong>.gpx</strong> file and include: race name, date, location, category (Elite / U23 / Junior / Allievi), discipline (Strada / Criterium / Cronometro) and gender (Maschile / Femminile).',
      r2_title: 'Report an error',
      r2_desc: 'Indicate the race name and the incorrect data — distance, elevation, date or anything else. I\'ll fix it as soon as possible. Bear in mind that distances and elevation gains are calculated automatically, so they may not be perfectly accurate.',
      r3_title: 'Get coached',
      r3_desc: 'I\'m an athletic trainer and sport scientist. Tell me about your level, your goals and the calendar you have in mind — let\'s see if we can work together.',
      r4_title: 'Anything else',
      r4_desc: 'Suggestions, feedback, questions, or you simply want to talk about cycling and training. Everything is welcome.',
      mail_btn: 'Send an email →',
      kofi_btn: 'Support',
    };
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
      const key = el.dataset.i18n!;
      if (t[key]) el.innerHTML = t[key];
    });
    const lead = document.getElementById('page-lead');
    if (lead) lead.innerHTML = `Write to <a href="mailto:bonvicin.coaching@gmail.com">bonvicin.coaching@gmail.com</a> — below you'll find what to include depending on the reason.`;
  }
</script>

<style>
  .page-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    grid-template-rows: 1fr auto;
    min-height: 100vh;
  }

  .sidebar-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 99;
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }
  .sidebar-overlay.open { display: block; }

  .sidebar {
    background: var(--bg2);
    border-right: 1px solid var(--border);
    position: sticky; top: 0;
    height: 100vh; overflow-y: auto;
    grid-row: 1 / 2;
  }

  .sidebar-inner { display: flex; flex-direction: column; padding: 1.5rem 1rem; height: 100%; gap: 1.25rem; }

  .brand { display: flex; align-items: center; gap: 0.85rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
  .brand-mark { font-family: var(--font-display); font-size: 0.85rem; font-weight: 800; letter-spacing: 0.08em; background: var(--text); color: var(--bg); padding: 0.3rem 0.5rem; border-radius: 2px; flex-shrink: 0; }
  .brand-name { font-family: var(--font-display); font-size: 1rem; font-weight: 700; letter-spacing: 0.02em; line-height: 1.1; }
  .brand-sub { font-family: var(--font-mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text3); margin-top: 0.15rem; }

  .sidebar-nav { display: flex; flex-direction: column; gap: 0.4rem; }
  .nav-btn { font-family: var(--font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text2); text-decoration: none; padding: 0.6rem 0.75rem; border: 1px solid var(--border); border-radius: 3px; background: transparent; transition: all 0.15s; display: block; }
  .nav-btn:hover { color: var(--text); border-color: var(--text2); background: var(--bg3); }
  .nav-btn.active { color: var(--accent); border-color: var(--accent); background: rgba(212, 64, 26, 0.05); }

  /* ── Mobile topbar ── */
  .mobile-topbar { display: none; }
  .mobile-menu-btn { background: none; border: 1px solid var(--border); border-radius: 3px; cursor: pointer; padding: 0.4rem 0.65rem; font-size: 1.1rem; color: var(--text); line-height: 1; transition: border-color 0.15s; }
  .mobile-menu-btn:hover { border-color: var(--text2); }

  .main { padding: 3rem 3.5rem; max-width: 780px; }
  .page-content { display: flex; flex-direction: column; gap: 3rem; }

  .page-header { border-bottom: 1px solid var(--border); padding-bottom: 2rem; }
  .page-tag { font-family: var(--font-mono); font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--accent); margin-bottom: 0.75rem; }
  .page-title { font-family: var(--font-display); font-size: 2.8rem; font-weight: 800; letter-spacing: 0.01em; line-height: 1; margin-bottom: 1rem; color: var(--text); }
  .page-lead { font-size: 1.05rem; color: var(--text2); line-height: 1.6; }
  .page-lead a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; font-weight: 500; }

  .section { display: flex; flex-direction: column; gap: 1rem; }
  .section-title { font-family: var(--font-display); font-size: 1.3rem; font-weight: 700; letter-spacing: 0.03em; color: var(--text); padding-bottom: 0.5rem; border-bottom: 1px solid var(--border); }

  .reasons-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .reason-card { border: 1px solid var(--border); border-radius: 4px; padding: 1.1rem; background: var(--bg2); }
  .reason-icon { font-size: 1.1rem; color: var(--accent); margin-bottom: 0.4rem; }
  .reason-title { font-family: var(--font-display); font-size: 0.95rem; font-weight: 700; letter-spacing: 0.03em; margin-bottom: 0.35rem; }
  .reason-desc { font-size: 0.8rem; line-height: 1.6; color: var(--text2); }
  .reason-desc strong { color: var(--text); font-weight: 500; }

  .mail-cta { padding-top: 0.5rem; border-top: 1px solid var(--border); display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .mail-btn { font-family: var(--font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.8rem 1.5rem; border-radius: 3px; text-decoration: none; display: inline-block; background: var(--text); color: var(--bg); border: 1px solid var(--text); transition: all 0.15s; }
  .mail-btn:hover { background: var(--accent); border-color: var(--accent); }
  .mail-btn--secondary { background: transparent; color: var(--text); border-color: var(--border); }
  .mail-btn--secondary:hover { background: var(--bg3); border-color: var(--text2); color: var(--text); }
  .mail-btn--kofi { background: #FF5E5B; color: #fff; border-color: #FF5E5B; }
  .mail-btn--kofi:hover { background: #e54c49; border-color: #e54c49; color: #fff; }

  footer { grid-column: 1 / -1; grid-row: 2; text-align: center; padding: 1rem 1.25rem; background: var(--bg2); color: var(--text2); font-size: 0.8rem; border-top: 1px solid var(--border); flex-shrink: 0; }
  footer a { color: var(--text2); text-decoration: none; font-weight: 500; transition: color 0.2s; }
  footer a:hover { color: var(--accent); }

  @media (max-width: 768px) {
    .page-layout { grid-template-columns: 1fr; }

    .mobile-topbar { display: flex; align-items: center; padding: 0.75rem 1rem; border-bottom: 1px solid var(--border); background: var(--bg); position: sticky; top: 0; z-index: 10; margin-bottom: 1.5rem; }

    .sidebar {
      position: fixed !important;
      top: 0; left: 0;
      height: 100dvh !important;
      width: 285px;
      z-index: 100;
      transform: translateX(-100%);
      box-shadow: none;
      overflow-y: auto;
    }
    .sidebar.open { transform: translateX(0); box-shadow: 4px 0 32px rgba(0,0,0,0.18); }
    .sidebar-inner { height: auto; min-height: 100%; padding-bottom: calc(1.25rem + env(safe-area-inset-bottom, 1rem)); }

    .main { padding: 0 1rem calc(1.5rem + env(safe-area-inset-bottom, 0.5rem)); }
    .reasons-grid { grid-template-columns: 1fr; }
    .page-title { font-size: 2rem; }
  }
</style>